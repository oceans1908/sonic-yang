module openconfig-bgp-deviation {

  yang-version "1";

  // namespace
  namespace "http://openconfig.net/yang/bgp/deviation/extension";

  prefix "oc-bgp-dev";

  // import some basic types
  import openconfig-network-instance { prefix oc-netinst; }
  import openconfig-extensions { prefix oc-ext; }
  import openconfig-rib-bgp { prefix oc-rib-bgp; }
  import openconfig-bgp-ext { prefix oc-bgp-ext; }

  import sonic-codegen { prefix sonic-codegen; }

  organization
    "SONiC";

  contact
    "SONiC";

  description
    "This module describes a YANG model for BGP protocol
    configuration deviations.";

  oc-ext:openconfig-version "1.0.0";

  revision "2021-06-17" {
    description
      "Attributes set is enclosed with state container.";
    reference "1.0.0";
  }

  revision "2021-06-04" {
    description
      "Add SONiC specific BGP deviations.";
    reference "0.1.0";
  }

  grouping bgp-deviation-attr-sets-state {
    description
      "Operational data for PATH attributes";
    container attr-sets {
      config false;
      description
        "Various PATH attributes for a given prefix.";
      container state {
        config false;
        description
          "State information relating to the PATH attributes.";
        
        leaf weight {
          type uint32;
          description
            "This indicates the weight value for the neighbor's routes";
        }
        uses oc-rib-bgp:bgp-shared-common-attr-state;
        uses oc-rib-bgp:bgp-community-attr-state;
        uses oc-rib-bgp:bgp-extended-community-attr-state;
      }
      uses oc-rib-bgp:bgp-aggregator-attr-top;
      uses oc-rib-bgp:bgp-as-path-attr-top;
    }
  }

