      description
         "Augmenting the state container to add the graceful restart information.";

      leaf peer-mode {
         type enumeration {
            enum HELPER_ONLY {
               description
                  "The local router is operating in helper-only mode, and
                  hence will not retain forwarding state during a local
                  session restart, but will do so during a restart of the
                  remote peer.";
            }
            enum BILATERAL {
               description
                  "The local router is operating in both helper mode, and
                  hence retains forwarding state during a remote restart,
               and also maintains forwarding state during local session
                  restart.";
            }
            enum REMOTE_HELPER {
               description
                  "The local system is able to retain routes during restart
                  but the remote system is only able to act as a helper.";
            }
         }
         description
            "This leaf indicates the mode of the peer in the context of BGP graceful restart.";
      }
      leaf remaining-time-restart-timer {
         type uint16;
         description
            "The remaining time until the timer expires is measured in seconds.";
      }
      leaf remaining-time-stalepath-timer {
         type uint16;
         description
            "The remaining time until deleting stale routes after receiving an End-of-RIB (EOR) message from a restarting router in seconds.";
      }
      leaf restart-state-bit {
         type boolean;
         description
            "Whether the BGP Peer has restarted.";
      }
   }

