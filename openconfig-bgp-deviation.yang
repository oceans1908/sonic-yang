      description
         "Augmenting the state container to add the peer-mode leaf.";

      leaf forwarding-state-bit {
         type boolean;
         description
            "whether the forwarding state for routes that were advertised with the given AFI and SAFI has indeed been preserved during the previous BGP restart.";
      }
      leaf end-of-rib-sent {
         type boolean;
         description
            "Whether finished sending all its routing updates after a session restart.";
      }
      leaf end-of-rib-sent-after-update {
         type boolean;
         description
            "Whether End-of-RIB marker is sent pecifically after all the necessary routing updates have been transmitted following a session restart.";
      }
      leaf end-of-rib-received {
         type boolean;
         description
            "Whether the BGP Peer has completed sending all its initial routing updates after a session restart.";
      }
      leaf stale-path-time {
         type uint16;
         description
            "The time this router will wait before deleting stale routes after receiving an End-of-RIB message from a restarting router in seconds.";
      }
      leaf selection-deferral-time {
         type uint16;
         description
            "The time this router should defer its route selection process after a restart in seconds.";
      }
   }

