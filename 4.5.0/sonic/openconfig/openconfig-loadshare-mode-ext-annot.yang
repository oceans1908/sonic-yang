    deviation /oc-lb-mode-ext:loadshare/oc-lb-mode-ext:hash-algorithm/oc-lb-mode-ext:state {
        deviate add {
            sonic-ext:subtree-transformer "loadshare_mode_state_xfmr";
        }
    }

    deviation /oc-lb-mode-ext:loadshare/oc-lb-mode-ext:rh-global-attrs/oc-lb-mode-ext:state {
        deviate add {
            sonic-ext:subtree-transformer "loadshare_mode_state_xfmr";
        }
    }

    deviation /oc-lb-mode-ext:loadshare/oc-lb-mode-ext:rh-attrs/oc-lb-mode-ext:rh-attr/oc-lb-mode-ext:state {
        deviate add {
