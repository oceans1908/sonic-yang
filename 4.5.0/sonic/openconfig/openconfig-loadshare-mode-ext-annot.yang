        }
    }

    deviation /oc-lb-mode-ext:loadshare/oc-lb-mode-ext:offset-attrs/oc-lb-mode-ext:config {
        deviate add {
            sonic-ext:table-name "ECMP_LOADSHARE_TABLE_OFFSET";
            sonic-ext:key-transformer "loadshare_mode_offset_key_xfmr";
        }
    }

    deviation /oc-lb-mode-ext:loadshare/oc-lb-mode-ext:ingress-port/oc-lb-mode-ext:config {
        deviate add {
            sonic-ext:table-name "ECMP_LOADSHARE_TABLE_INGRESS_PORT";
            sonic-ext:key-transformer "loadshare_mode_ingress_port_key_xfmr";
        }
    }

    deviation /oc-lb-mode-ext:loadshare/oc-lb-mode-ext:roce-attrs/oc-lb-mode-ext:config {
        deviate add {
            sonic-ext:table-name "ECMP_LOADSHARE_TABLE_ROCE";
