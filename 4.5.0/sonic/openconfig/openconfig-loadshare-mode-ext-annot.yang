        }
    }

    deviation /oc-lb-mode-ext:loadshare/oc-lb-mode-ext:rh-attrs {
        deviate add {
            sonic-ext:table-name "ECMP_LOADSHARE_TABLE_RH";
        }
    }

    deviation /oc-lb-mode-ext:loadshare/oc-lb-mode-ext:offset-attrs {
        deviate add {
            sonic-ext:table-transformer "loadshare_offset_table_xfmr";
        }
    }

    deviation /oc-lb-mode-ext:loadshare/oc-lb-mode-ext:ingress-port {
        deviate add {
            sonic-ext:table-transformer "loadshare_ingress_port_table_xfmr";
        }
    }

    deviation /oc-lb-mode-ext:loadshare/oc-lb-mode-ext:roce-attrs {
        deviate add {
            sonic-ext:table-transformer "loadshare_roce_table_xfmr";
        }
    }

    deviation /oc-lb-mode-ext:loadshare/oc-lb-mode-ext:udf-attrs/oc-lb-mode-ext:udf-attr {
        deviate add {
            sonic-ext:table-name "ECMP_LOADSHARE_TABLE_UDF";
        }
    }

    deviation /oc-lb-mode-ext:loadshare/oc-lb-mode-ext:rh-global-attrs {
        deviate add {
            sonic-ext:table-owner "false";
            sonic-ext:table-name "SWITCH";
            sonic-ext:key-transformer "switch_key_xfmr";
        }
    }

    deviation /oc-lb-mode-ext:loadshare/oc-lb-mode-ext:rh-global-attrs/oc-lb-mode-ext:config/oc-lb-mode-ext:threshold {
        deviate add {
            sonic-ext:field-name "ecmp_hash_rh_nhg_opt_th";
        }
    }

    deviation /oc-lb-mode-ext:loadshare/oc-lb-mode-ext:hash-algorithm {
        deviate add {
            sonic-ext:table-owner "false";
            sonic-ext:table-name "SWITCH";
            sonic-ext:key-transformer "switch_key_xfmr";
        }
    }

    deviation /oc-lb-mode-ext:loadshare/oc-lb-mode-ext:hash-algorithm/oc-lb-mode-ext:config/oc-lb-mode-ext:algorithm {
        deviate add {
            sonic-ext:field-name "ecmp_hash_algorithm";
        }
